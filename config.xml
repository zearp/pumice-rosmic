<?xml version="1.0" encoding="utf-8"?>
<image schemaversion="7.5" name="Pumice">
	<description type="system">
		<author>zearp</author>
		<contact>https://github.com/zearp/pumice-rosmic</contact>
		<specification>Rocky Linux 10 (COSMIC desktop)</specification>
	</description>
	<preferences>
		<version>10</version>
		<packagemanager>dnf</packagemanager>
		<locale>en_GB</locale>
		<keytable>us</keytable>
		<timezone>Europe/Amsterdam</timezone>
		<release-version>10</release-version>
	</preferences>
	<repository type="rpm-md" alias="baseos" priority="1">
		<source path="https://download.rockylinux.org/pub/rocky/$releasever/BaseOS/$basearch/os">
			<signing key="file:///usr/share/distribution-gpg-keys/rocky/RPM-GPG-KEY-Rocky-$releasever"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="appstream" priority="1">
		<source path="https://download.rockylinux.org/pub/rocky/$releasever/AppStream/$basearch/os">
			<signing key="file:///usr/share/distribution-gpg-keys/rocky/RPM-GPG-KEY-Rocky-$releasever"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="crb" priority="1">
		<source path="https://download.rockylinux.org/pub/rocky/$releasever/CRB/$basearch/os">
			<signing key="file:///usr/share/distribution-gpg-keys/rocky/RPM-GPG-KEY-Rocky-$releasever"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="extras" priority="1">
		<source path="https://download.rockylinux.org/pub/rocky/$releasever/extras/$basearch/os">
			<signing key="file:///usr/share/distribution-gpg-keys/rocky/RPM-GPG-KEY-Rocky-$releasever"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="epel" priority="2">
		<source path="https://dl.fedoraproject.org/pub/epel/$releasever/Everything/x86_64/">
			<signing key="file:///usr/share/distribution-gpg-keys/epel/RPM-GPG-KEY-EPEL-$releasever"/>
		</source>
	</repository>
	<profiles>
		<profile name="Pumice" description="Rocky Linux 10 (COSMIC desktop)"/>
	</profiles>
	<packages type="image" profiles="Pumice">
		<!-- groups to install, see "dnf group list" and "https://dnf.readthedocs.io/en/latest/command_ref.html" for more info -->
		<namedCollection name="anaconda-tools"/>
		<namedCollection name="core"/>
		<namedCollection name="fonts"/>
		<namedCollection name="hardware-support"/>
		<namedCollection name="multimedia"/>
		<namedCollection name="networkmanager-submodules"/>
		<namedCollection name="standard"/>
		<!-- packages to ignore/make sure are not installed -->
		<ignore name="PackageKit-command-not-found"/>
		<ignore name="device-mapper-multipath"/>
		<ignore name="fcoe-utils"/>
		<ignore name="gfs2-utils"/>
		<ignore name="kernel-*debug*"/>
		<ignore name="kernel-dump"/>
		<ignore name="kernel-srpm-macros"/>
		<ignore name="malcontent-control"/>
		<ignore name="python3-boto3"/>
		<ignore name="qemu-user-static"/>
		<ignore name="reiserfs-utils"/>
		<!-- packages, be careful when removing as some packages are required by the installer -->
		<package name="amd-ucode-firmware"/>
		<package name="anaconda"/>
		<package name="anaconda-install-env-deps"/>
		<package name="anaconda-live"/>
		<package name="bat"/>
		<package name="bind-utils"/>
		<package name="btop"/>
		<package name="cockpit"/>
		<package name="cockpit-files"/>
		<package name="cockpit-packagekit"/>
		<package name="cockpit-storaged"/>
		<package name="dbus-daemon"/>
		<package name="ddcutil"/>
		<package name="dialog"/>
		<package name="dracut-live"/>
		<package name="elrepo-release"/>
		<package name="epel-release"/>
		<package name="fastfetch"/>
		<package name="flatpak"/>
		<package name="flatseal"/>
		<package name="fstrm"/>
		<package name="firefox"/>
		<package name="git"/>
		<package name="git-lfs"/>
		<package name="glibc-all-langpacks"/>
		<package name="grub2-efi-x64"/>
		<package name="grub2-efi-x64-cdboot"/>
		<package name="grub2-efi-x64-modules"/>
		<package name="grub2-pc"/>
		<package name="grub2-pc-modules"/>
		<package name="hddtemp"/>
		<package name="htop"/>
		<package name="ipcalc"/>
		<package name="iperf3"/>
		<package name="isomd5sum"/>
		<package name="kernel"/>
		<package name="kernel-core"/>
		<package name="kernel-modules"/>
		<package name="kernel-modules-extra"/>
		<package name="less"/>
		<package name="libva-intel-hybrid-driver"/>
		<package name="livesys-scripts"/>
		<package name="lm_sensors"/>
		<package name="man-db"/>
		<package name="mc"/>
		<package name="microcode_ctl"/>
		<package name="nano"/>
		<package name="ncdu"/>
		<package name="NetworkManager-tui"/>
		<package name="openssh-server"/>
		<package name="pcp"/>
		<package name="perl-Image-ExifTool"/>
		<package name="pigz"/>
		<package name="plymouth"/>
		<package name="plymouth-theme-spinner"/>
		<package name="python3-pcp"/>
		<package name="ripgrep"/>
		<package name="rootfiles"/>
		<package name="screen"/>
		<package name="setroubleshoot-server"/>
		<package name="shim-signed-x64"/>
		<package name="sqlite"/>
		<package name="stress-ng"/>
		<package name="systemd-oomd-defaults"/>
		<package name="systemd-resolved"/>
		<package name="thermald"/>
		<package name="telnet"/>
		<package name="tio"/>
		<package name="traceroute"/>
		<package name="tuned"/>
		<package name="tuned-ppd"/>
		<package name="whois"/>
		<package name="xdg-utils"/>
		<package name="yum-utils"/>
		<package name="zram-generator"/>
		<package name="zsh"/>
		<package name="zstd"/>
	</packages>
	<!-- bootstrap packahes -->
	<packages type="bootstrap">
		<package name="basesystem"/>
		<package name="filesystem"/>
	</packages>
	<preferences profiles="Pumice">
		<type image="iso" publisher="Pumice" volid="Pumice" primary="true" flags="dmsquash" filesystem="erofs" fscreateoptions="--workers=NPROC_PLACEHOLDER -Efragments -C 1048576" erofscompression="lzma,level=9" mediacheck="true" firmware="uefi" efifatimagesize="30" kernelcmdline="quiet rhgb systemd.show_status=auto biosdevname=0 net.ifnames=0 thunderbolt.host_reset=false inst.kdump_addon=off inst.geoloc=0 inst.keymap=US" bundle_format="Pumice-Rocky-Cosmic-%v-%A">
			<bootloader name="grub2" grub_template="grub.template" console="console" timeout="10"/>
		</type>
	</preferences>
	<users profiles="Pumice">
		<!-- password will be erased by config.sh -->
		<user name="root" groups="root" password="linux" home="/root" pwdformat="plain" />
	</users>
</image>
